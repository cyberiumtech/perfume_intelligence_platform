# ============================================================
# Perfume Intelligence Platform — Docker Environment Template
# Copy to .env and fill in real values before running docker-compose
# ============================================================

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=perfume_intelligence_db

# Application
DATABASE_URL=postgresql://postgres:changeme_in_production@postgres:5432/perfume_intelligence_db
LOG_LEVEL=INFO

# Scraper Worker
SCRAPER_POLL_INTERVAL=30
SCRAPE_INTERVAL_HOURS=4
SCRAPER_BATCH_SIZE=25
DELIST_THRESHOLD_MINUTES=1440

# LLM Providers (fill in as needed)
OLLAMA_HOST=http://ollama:11434
LLM_PROVIDER=ollama

# Google Gemini (optional — used as LLM fallback)
# GEMINI_API_KEY=your-gemini-api-key

# AWS Bedrock (optional — used as LLM fallback)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
